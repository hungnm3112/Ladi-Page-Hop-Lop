<!-- ══ SCRIPTS ══════════════════════════════════════════════ -->
<script>
;(function () {
  'use strict'

  // ── Countdown ──────────────────────────────────────────
  var eventDateTime = new Date('<%= content.event.date %>T<%= content.event.time || "13:00" %>:00')
  var cdDays    = document.getElementById('cd-days')
  var cdHours   = document.getElementById('cd-hours')
  var cdMinutes = document.getElementById('cd-minutes')
  var cdSeconds = document.getElementById('cd-seconds')
  var cdBox     = document.getElementById('countdown')

  function pad(n) { return String(n).padStart(2, '0') }

  function tick() {
    var diff = eventDateTime - Date.now()
    if (diff <= 0) {
      cdBox.innerHTML = '<div class="cd-done"><i class="fa-solid fa-party-popper" aria-hidden="true"></i><span>Sự kiện đã diễn ra!</span></div>'
      return
    }
    cdDays.textContent    = pad(Math.floor(diff / 86400000))
    cdHours.textContent   = pad(Math.floor((diff % 86400000) / 3600000))
    cdMinutes.textContent = pad(Math.floor((diff % 3600000) / 60000))
    cdSeconds.textContent = pad(Math.floor((diff % 60000) / 1000))
  }
  tick()
  setInterval(tick, 1000)

  // ── Registration modal ───────────────────────────────
  var registerModal = document.getElementById('register-modal')
  var registerForm = document.getElementById('register-form')
  var registerSubmit = document.getElementById('register-submit')
  var registerMessage = document.getElementById('register-form-message')
  var registerModalBg = document.getElementById('register-modal-bg')
  var closeRegisterModalBtn = document.getElementById('close-register-modal')

  function setRegisterMessage(message, type) {
    if (!registerMessage) return
    if (!message) {
      registerMessage.hidden = true
      registerMessage.textContent = ''
      registerMessage.className = 'register-form-message'
      return
    }
    registerMessage.hidden = false
    registerMessage.textContent = message
    registerMessage.className = 'register-form-message ' + (type || 'info')
  }

  function openRegisterModal() {
    if (!registerModal) return
    registerModal.classList.add('active')
    registerModal.setAttribute('aria-hidden', 'false')
    document.body.style.overflow = 'hidden'
    setRegisterMessage('')
  }

  function closeRegisterModal() {
    if (!registerModal) return
    registerModal.classList.remove('active')
    registerModal.setAttribute('aria-hidden', 'true')
    document.body.style.overflow = ''
  }

  document.querySelectorAll('[data-register-open]').forEach(function(trigger) {
    trigger.addEventListener('click', function(e) {
      e.preventDefault()
      openRegisterModal()
    })
  })

  if (closeRegisterModalBtn) closeRegisterModalBtn.addEventListener('click', closeRegisterModal)
  if (registerModalBg) registerModalBg.addEventListener('click', closeRegisterModal)

  // ── Scroll focused input into view khi bàn phím ảo che (mobile) ──
  function scrollFocusedIntoView(el) {
    if (!el) return
    var vp = window.visualViewport
    var rect = el.getBoundingClientRect()
    var visibleBottom = vp ? vp.height : window.innerHeight
    var margin = 24
    if (rect.bottom > visibleBottom - margin || rect.top < margin) {
      var container = el.closest('.register-modal, .gallery-upload-modal, .guestbook-modal')
      if (container) {
        container.scrollTop += rect.bottom - visibleBottom + margin + 40
      } else {
        el.scrollIntoView({ block: 'center', behavior: 'smooth' })
      }
    }
  }

  document.querySelectorAll('#register-form input, #register-form textarea, #register-form select, #gallery-upload-form input, #gallery-upload-form select, #guestbook-form input, #guestbook-form textarea').forEach(function(el) {
    el.addEventListener('focus', function() {
      window.setTimeout(function() { scrollFocusedIntoView(el) }, 320)
    })
  })

  if (window.visualViewport) {
    window.visualViewport.addEventListener('resize', function() {
      var active = document.activeElement
      if (active && active.matches && active.matches('#register-form input, #register-form textarea, #register-form select, #guestbook-form input, #guestbook-form textarea')) {
        window.setTimeout(function() { scrollFocusedIntoView(active) }, 120)
      }
    })
  }

  // ── Smooth scroll for nav links ────────────────────────
  document.querySelectorAll('a[href^="#"]').forEach(function(a) {
    a.addEventListener('click', function(e) {
      if (a.hasAttribute('data-register-open')) return
      var href = a.getAttribute('href')
      if (href === '#') return
      var target = document.querySelector(href)
      if (target) {
        e.preventDefault()
        target.scrollIntoView({ behavior: 'smooth', block: 'start' })
      }
    })
  })

  // ── Mobile nav toggle ─────────────────────────────────
  var navToggle = document.getElementById('navbar-toggle')
  var mobileNav = document.getElementById('navbar-mobile')

  function closeMobileNav() {
    if (!navToggle || !mobileNav) return
    navToggle.classList.remove('active')
    navToggle.setAttribute('aria-expanded', 'false')
    mobileNav.hidden = true
  }

  if (navToggle && mobileNav) {
    navToggle.addEventListener('click', function() {
      var isOpen = navToggle.classList.toggle('active')
      navToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false')
      mobileNav.hidden = !isOpen
    })

    mobileNav.querySelectorAll('a').forEach(function(link) {
      link.addEventListener('click', closeMobileNav)
    })
  }

  // ── Active nav highlight on scroll ────────────────────
  var navAnchors = Array.from(document.querySelectorAll('.navbar-links a'))
  var sectionIds = navAnchors.map(function(a) { return a.getAttribute('href').replace('#', '') })
  var sections   = sectionIds.map(function(id) { return document.getElementById(id) }).filter(Boolean)

  function updateActiveNav() {
    var scrollY = window.scrollY + 80
    var activeIdx = 0
    sections.forEach(function(sec, i) {
      if (sec && sec.offsetTop <= scrollY) activeIdx = i
    })
    navAnchors.forEach(function(a, i) { a.classList.toggle('active', i === activeIdx) })
  }
  window.addEventListener('scroll', updateActiveNav, { passive: true })
  updateActiveNav()

  // ── Registered tabs ───────────────────────────────────
  var registeredTabs = Array.from(document.querySelectorAll('[data-registered-tab]'))
  var registeredPanels = Array.from(document.querySelectorAll('[data-registered-panel]'))
  var classFilterButtons = Array.from(document.querySelectorAll('[data-class-filter]'))
  var detailRows = Array.from(document.querySelectorAll('[data-registered-row]'))
  var pagination = document.getElementById('registered-pagination')
  var selectedClassFilter = 'all'
  var currentRegisteredPage = 1
  var registeredPageSize = 10

  function activateRegisteredTab(key) {
    registeredTabs.forEach(function(tab) {
      tab.classList.toggle('active', tab.dataset.registeredTab === key)
    })
    registeredPanels.forEach(function(panel) {
      panel.classList.toggle('active', panel.dataset.registeredPanel === key)
    })
  }

  registeredTabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      activateRegisteredTab(tab.dataset.registeredTab)
    })
  })

  function getFilteredRegisteredRows() {
    return detailRows.filter(function(row) {
      return selectedClassFilter === 'all' || row.dataset.className === selectedClassFilter
    })
  }

  function renderRegisteredPagination(totalPages) {
    if (!pagination) return
    pagination.innerHTML = ''
    if (totalPages <= 1) return

    for (var i = 1; i <= totalPages; i += 1) {
      var btn = document.createElement('button')
      btn.type = 'button'
      btn.className = 'registered-page-btn' + (i === currentRegisteredPage ? ' active' : '')
      btn.textContent = i
      btn.dataset.page = String(i)
      btn.addEventListener('click', function() {
        currentRegisteredPage = parseInt(this.dataset.page, 10)
        renderRegisteredList()
      })
      pagination.appendChild(btn)
    }
  }

  function renderRegisteredList() {
    if (detailRows.length === 0) return
    var filteredRows = getFilteredRegisteredRows()
    var totalPages = Math.max(1, Math.ceil(filteredRows.length / registeredPageSize))
    if (currentRegisteredPage > totalPages) currentRegisteredPage = totalPages
    var start = (currentRegisteredPage - 1) * registeredPageSize
    var end = start + registeredPageSize

    detailRows.forEach(function(row) { row.hidden = true })
    filteredRows.slice(start, end).forEach(function(row, index) {
      row.hidden = false
      var indexCell = row.querySelector('[data-row-index]')
      if (indexCell) indexCell.textContent = String(start + index + 1)
    })

    renderRegisteredPagination(totalPages)
  }

  classFilterButtons.forEach(function(btn) {
    btn.addEventListener('click', function() {
      selectedClassFilter = btn.dataset.classFilter
      currentRegisteredPage = 1
      classFilterButtons.forEach(function(item) {
        item.classList.toggle('active', item === btn)
      })
      renderRegisteredList()
    })
  })

  document.querySelectorAll('[data-registered-jump]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var className = btn.dataset.registeredJump
      activateRegisteredTab('list')
      currentRegisteredPage = 1
      selectedClassFilter = className
      classFilterButtons.forEach(function(item) {
        item.classList.toggle('active', item.dataset.classFilter === className)
      })
      renderRegisteredList()
    })
  })

  renderRegisteredList()
  document.querySelectorAll('.bar-fill[data-bar-width]').forEach(function(bar) {
    var barWidth = Number(bar.getAttribute('data-bar-width'))
    if (!isFinite(barWidth)) barWidth = 0
    barWidth = Math.max(0, Math.min(100, barWidth))
    bar.style.width = barWidth + '%'
  })

  // ── Scroll reveal ──────────────────────────────────────
  if ('IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible')
          obs.unobserve(entry.target)
        }
      })
    }, { threshold: 0.1 })
    document.querySelectorAll('.reveal').forEach(function(el) { obs.observe(el) })
  } else {
    document.querySelectorAll('.reveal').forEach(function(el) { el.classList.add('visible') })
  }

  // ── Gallery carousel ───────────────────────────────────
  var track = document.getElementById('carousel-track')
  if (track) {
    var slides  = Array.from(track.querySelectorAll('.carousel-slide'))
    var dots    = Array.from(document.querySelectorAll('.carousel-dot'))
    var counter = document.getElementById('slide-counter')
    var total   = slides.length
    var current = 0
    var autoSlideTimer = null
    var autoSlideDelay = 1800

    slides.forEach(function(slide) {
      var img = slide.querySelector('img')
      if (!img) return

      function markOrientation() {
        slide.classList.toggle('is-portrait', img.naturalHeight > img.naturalWidth)
      }

      if (img.complete) markOrientation()
      else img.addEventListener('load', markOrientation, { once: true })
    })

    function stopAutoSlide() {
      if (autoSlideTimer) {
        window.clearInterval(autoSlideTimer)
        autoSlideTimer = null
      }
    }

    function startAutoSlide() {
      if (total <= 1 || autoSlideTimer || document.hidden) return
      autoSlideTimer = window.setInterval(function() {
        goTo(current + 1)
      }, autoSlideDelay)
    }

    function resetAutoSlide() {
      stopAutoSlide()
      startAutoSlide()
    }

    function goTo(idx) {
      if (total === 0) return
      if (idx < 0) idx = total - 1
      if (idx >= total) idx = 0
      current = idx
      track.style.transform = 'translateX(-' + (100 * current) + '%)'
      dots.forEach(function(d, i) { d.classList.toggle('active', i === current) })
      if (counter) counter.textContent = (current + 1) + ' / ' + total
    }

    var prevBtn = document.getElementById('carousel-prev')
    var nextBtn = document.getElementById('carousel-next')
    if (prevBtn) prevBtn.addEventListener('click', function() {
      goTo(current - 1)
      resetAutoSlide()
    })
    if (nextBtn) nextBtn.addEventListener('click', function() {
      goTo(current + 1)
      resetAutoSlide()
    })

    dots.forEach(function(d) {
      d.addEventListener('click', function() {
        goTo(parseInt(d.dataset.idx, 10))
        resetAutoSlide()
      })
    })

    // Touch swipe
    var touchStartX = 0
    track.addEventListener('touchstart', function(e) {
      stopAutoSlide()
      touchStartX = e.touches[0].clientX
    }, { passive: true })
    track.addEventListener('touchend', function(e) {
      var dx = e.changedTouches[0].clientX - touchStartX
      if (Math.abs(dx) > 50) goTo(dx < 0 ? current + 1 : current - 1)
      startAutoSlide()
    }, { passive: true })

    var carouselRoot = track.closest('.gallery-carousel')
    if (carouselRoot) {
      carouselRoot.addEventListener('mouseenter', stopAutoSlide)
      carouselRoot.addEventListener('mouseleave', startAutoSlide)
      carouselRoot.addEventListener('focusin', stopAutoSlide)
      carouselRoot.addEventListener('focusout', startAutoSlide)
    }
    document.addEventListener('visibilitychange', function() {
      if (document.hidden) stopAutoSlide()
      else startAutoSlide()
    })

    goTo(0)
    startAutoSlide()
  }

  // ── Gallery upload modal ───────────────────────────────
  var galleryUploadModal = document.getElementById('gallery-upload-modal')
  var galleryUploadOpen = document.getElementById('open-gallery-upload-modal')
  var galleryUploadClose = document.getElementById('close-gallery-upload-modal')
  var galleryUploadBg = document.getElementById('gallery-upload-modal-bg')
  var galleryUploadForm = document.getElementById('gallery-upload-form')
  var galleryUploadSubmit = document.getElementById('gallery-upload-submit')
  var galleryUploadMessage = document.getElementById('gallery-upload-form-message')
  var galleryFileInput = document.getElementById('gallery-memory-images')
  var galleryFileSummary = document.getElementById('gallery-file-summary')

  function setGalleryUploadMessage(message, type) {
    if (!galleryUploadMessage) return
    if (!message) {
      galleryUploadMessage.hidden = true
      galleryUploadMessage.textContent = ''
      galleryUploadMessage.className = 'register-form-message'
      return
    }
    galleryUploadMessage.hidden = false
    galleryUploadMessage.textContent = message
    galleryUploadMessage.className = 'register-form-message ' + (type || 'info')
  }

  function openGalleryUploadModal() {
    if (!galleryUploadModal) return
    galleryUploadModal.classList.add('active')
    galleryUploadModal.setAttribute('aria-hidden', 'false')
    document.body.style.overflow = 'hidden'
    setGalleryUploadMessage('')
  }

  function closeGalleryUploadModal() {
    if (!galleryUploadModal) return
    galleryUploadModal.classList.remove('active')
    galleryUploadModal.setAttribute('aria-hidden', 'true')
    document.body.style.overflow = ''
  }

  if (galleryUploadOpen) {
    galleryUploadOpen.addEventListener('click', function() {
      openGalleryUploadModal()
    })
  }
  if (galleryUploadClose) galleryUploadClose.addEventListener('click', closeGalleryUploadModal)
  if (galleryUploadBg) galleryUploadBg.addEventListener('click', closeGalleryUploadModal)

  if (galleryFileInput) {
    galleryFileInput.addEventListener('change', function() {
      var files = Array.from(galleryFileInput.files || [])
      if (files.length > 3) {
        galleryFileInput.value = ''
        if (galleryFileSummary) galleryFileSummary.textContent = 'JPG, PNG, WebP'
        setGalleryUploadMessage('Chỉ được chọn tối đa 3 ảnh mỗi lần.', 'error')
        return
      }
      if (galleryFileSummary) {
        galleryFileSummary.textContent = files.length ? files.map(function(file) { return file.name }).join(', ') : 'JPG, PNG, WebP'
      }
      setGalleryUploadMessage('')
    })
  }

  if (galleryUploadForm) {
    galleryUploadForm.addEventListener('submit', function(e) {
      e.preventDefault()
      var files = galleryFileInput ? Array.from(galleryFileInput.files || []) : []
      var name = galleryUploadForm.querySelector('[name="name"]').value.trim()
      var className = galleryUploadForm.querySelector('[name="className"]').value.trim()
      var description = galleryUploadForm.querySelector('[name="description"]').value.trim()

      if (!files.length) {
        setGalleryUploadMessage('Vui lòng chọn ít nhất 1 ảnh.', 'error')
        return
      }
      if (files.length > 3) {
        setGalleryUploadMessage('Chỉ được chọn tối đa 3 ảnh mỗi lần.', 'error')
        return
      }
      if (!name || !className || !description) {
        setGalleryUploadMessage('Vui lòng nhập họ tên, lớp và mô tả.', 'error')
        return
      }

      var formData = new FormData(galleryUploadForm)
      galleryUploadSubmit.disabled = true
      galleryUploadSubmit.textContent = 'ĐANG GỬI...'
      setGalleryUploadMessage('')

      fetch('/gallery-memory', {
        method: 'POST',
        body: formData
      })
      .then(function(r) { return r.json() })
      .then(function(result) {
        if (!result.ok) {
          setGalleryUploadMessage(result.message || 'Không thể gửi ảnh lúc này.', 'error')
          return
        }
        setGalleryUploadMessage('Đã gửi ảnh thành công. Đang cập nhật thư viện...', 'success')
        galleryUploadForm.reset()
        if (galleryFileSummary) galleryFileSummary.textContent = 'JPG, PNG, WebP'
        window.location.hash = 'thu-vien-anh'
        window.setTimeout(function() { window.location.reload() }, 700)
      })
      .catch(function() {
        setGalleryUploadMessage('Lỗi kết nối. Vui lòng thử lại.', 'error')
      })
      .finally(function() {
        galleryUploadSubmit.disabled = false
        galleryUploadSubmit.textContent = 'GỬI ẢNH'
      })
    })
  }

  // ── Hero constellation spotlight ───────────────────────
  var constellation = document.querySelector('[data-hero-constellation]')
  if (constellation) {
    var allNodes = Array.from(constellation.querySelectorAll('[data-constellation-node]'))
    var labelNodes = allNodes.filter(function(n) {
      return n.querySelector('.hero-constellation-label')
    })

    if (labelNodes.length > 0) {
      var spotlightIdx = 0
      var spotlightPaused = false
      var spotlightTimer = null

      var setSpotlight = function(idx) {
        labelNodes.forEach(function(n, i) {
          n.classList.toggle('is-spotlight', i === idx)
        })
      }

      var nextSpotlight = function() {
        if (spotlightPaused) return
        spotlightIdx = (spotlightIdx + 1) % labelNodes.length
        setSpotlight(spotlightIdx)
      }

      labelNodes.forEach(function(n, i) {
        n.addEventListener('mouseenter', function() {
          spotlightPaused = true
          spotlightIdx = i
          setSpotlight(i)
        })
        n.addEventListener('mouseleave', function() {
          spotlightPaused = false
        })
      })

      var startSpotlight = function() {
        if (spotlightTimer) return
        spotlightTimer = setInterval(nextSpotlight, 2800)
      }
      var stopSpotlight = function() {
        if (!spotlightTimer) return
        clearInterval(spotlightTimer)
        spotlightTimer = null
      }

      setSpotlight(0)
      startSpotlight()

      document.addEventListener('visibilitychange', function() {
        if (document.hidden) stopSpotlight()
        else startSpotlight()
      })
    }
  }

  // ── Guestbook modal ────────────────────────────────────
  var modal    = document.getElementById('guestbook-modal')
  var openBtn  = document.getElementById('open-guestbook-modal')
  var closeBtn = document.getElementById('close-guestbook-modal')
  var modalBg  = document.getElementById('guestbook-modal-bg')

  function openModal() {
    if (!modal) return
    modal.classList.add('active')
    modal.setAttribute('aria-hidden', 'false')
    document.body.style.overflow = 'hidden'
  }
  function closeModal() {
    if (!modal) return
    modal.classList.remove('active')
    modal.setAttribute('aria-hidden', 'true')
    document.body.style.overflow = ''
  }

  if (openBtn)  openBtn.addEventListener('click', openModal)
  if (closeBtn) closeBtn.addEventListener('click', closeModal)
  if (modalBg)  modalBg.addEventListener('click', closeModal)
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && registerModal && registerModal.classList.contains('active')) closeRegisterModal()
    if (e.key === 'Escape' && galleryUploadModal && galleryUploadModal.classList.contains('active')) closeGalleryUploadModal()
    if (e.key === 'Escape' && modal && modal.classList.contains('active')) closeModal()
  })

  if (registerForm) {
    registerForm.addEventListener('submit', function(e) {
      e.preventDefault()
      var formData = {
        name: registerForm.querySelector('[name="name"]').value.trim(),
        className: registerForm.querySelector('[name="className"]').value.trim(),
        phone: registerForm.querySelector('[name="phone"]').value.trim(),
        note: registerForm.querySelector('[name="note"]').value.trim()
      }

      if (!formData.name || !formData.className || !formData.phone) {
        setRegisterMessage('Vui lòng nhập đủ họ tên, lớp và số điện thoại.', 'error')
        return
      }

      registerSubmit.disabled = true
      registerSubmit.textContent = 'ĐANG GỬI...'
      setRegisterMessage('')

      fetch('/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formData)
      })
      .then(function(r) { return r.json() })
      .then(function(result) {
        if (!result.ok) {
          setRegisterMessage(result.message || 'Không thể đăng ký lúc này.', 'error')
          return
        }

        setRegisterMessage('Đăng ký thành công. Đang cập nhật danh sách...', 'success')
        registerForm.reset()
        window.location.hash = 'da-dang-ky'
        window.setTimeout(function() { window.location.reload() }, 700)
      })
      .catch(function() {
        setRegisterMessage('Lỗi kết nối. Vui lòng thử lại.', 'error')
      })
      .finally(function() {
        registerSubmit.disabled = false
        registerSubmit.textContent = 'GỬI ĐĂNG KÝ'
      })
    })
  }

  // Guestbook form submit
  var gbForm   = document.getElementById('guestbook-form')
  var gbSubmit = document.getElementById('gb-submit')
  if (gbForm) {
    gbForm.addEventListener('submit', function(e) {
      e.preventDefault()
      var name    = gbForm.querySelector('[name="name"]').value.trim()
      var cls     = gbForm.querySelector('[name="className"]').value.trim()
      var message = gbForm.querySelector('[name="message"]').value.trim()
      if (!name || !message) return

      gbSubmit.disabled = true
      gbSubmit.textContent = 'Đang gửi...'

      fetch('/guestbook', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: name, className: cls, message: message })
      })
      .then(function(r) { return r.json() })
      .then(function(result) {
        if (result.ok) {
          closeModal()
          gbForm.reset()
          var emptyState = document.querySelector('.guestbook-empty')
          if (emptyState) emptyState.remove()

          var scroller = document.querySelector('[data-guestbook-scroller]')
          var grid = scroller ? scroller.querySelector('.guestbook-grid') : null
          if (!scroller) {
            scroller = document.createElement('div')
            scroller.className = 'guestbook-scroller reveal visible'
            scroller.setAttribute('data-guestbook-scroller', '')
            grid = document.createElement('div')
            grid.className = 'guestbook-grid'
            scroller.appendChild(grid)
            var guestbookSection = document.querySelector('.guestbook-section .section-inner')
            if (guestbookSection) guestbookSection.appendChild(scroller)
          }

          var card = document.createElement('div')
          card.className = 'guestbook-card highlighted'
          card.innerHTML =
            '<p class="guestbook-quote">"' + message.replace(/</g, '&lt;').replace(/>/g, '&gt;') + '"</p>' +
            '<span class="guestbook-sep">——</span>' +
            '<div class="guestbook-meta">' +
              '<span class="guestbook-name">' + name.replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</span>' +
              (cls ? '<span class="guestbook-class">' + cls.replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</span>' : '') +
              '<span class="guestbook-date">' + (result.item && result.item.createdAtLabel ? result.item.createdAtLabel : '') + '</span>' +
            '</div>'
          grid.insertBefore(card, grid.firstChild)
          scroller.scrollTo({ left: 0, behavior: 'smooth' })
          if (typeof renderGuestbookDots === 'function') renderGuestbookDots()
          alert('Cảm ơn bạn đã gửi lời nhắn!')
        } else {
          alert('Lỗi: ' + (result.message || 'Vui lòng thử lại'))
        }
        gbSubmit.disabled = false
        gbSubmit.textContent = 'GỬI LỜI NHẮN'
      })
      .catch(function() {
        alert('Lỗi kết nối, thử lại nhé')
        gbSubmit.disabled = false
        gbSubmit.textContent = 'GỬI LỜI NHẮN'
      })
    })
  }

  // ── Guestbook horizontal pagination ────────────────────
  var gbScroller = document.querySelector('[data-guestbook-scroller]')
  var gbPagination = document.querySelector('[data-guestbook-pagination]')

  function gbGetPageCount() {
    if (!gbScroller) return 0
    var pageWidth = gbScroller.clientWidth
    if (pageWidth <= 0) return 0
    return Math.max(1, Math.ceil(gbScroller.scrollWidth / pageWidth))
  }

  function gbGetCurrentPage() {
    if (!gbScroller) return 0
    var pageWidth = gbScroller.clientWidth
    if (pageWidth <= 0) return 0
    return Math.round(gbScroller.scrollLeft / pageWidth)
  }

  function gbUpdateActiveDot() {
    if (!gbPagination) return
    var idx = gbGetCurrentPage()
    var dots = gbPagination.querySelectorAll('.guestbook-page-dot')
    dots.forEach(function(dot, i) { dot.classList.toggle('active', i === idx) })
  }

  function renderGuestbookDots() {
    if (!gbScroller || !gbPagination) return
    var total = gbGetPageCount()
    if (total <= 1) { gbPagination.innerHTML = ''; gbPagination.style.display = 'none'; return }
    gbPagination.style.display = ''
    var current = gbGetCurrentPage()
    var html = ''
    for (var i = 0; i < total; i++) {
      html += '<button type="button" class="guestbook-page-dot' + (i === current ? ' active' : '') + '" data-guestbook-page="' + i + '" aria-label="Trang ' + (i + 1) + '"></button>'
    }
    gbPagination.innerHTML = html
    gbPagination.querySelectorAll('.guestbook-page-dot').forEach(function(dot) {
      dot.addEventListener('click', function() {
        var idx = parseInt(dot.getAttribute('data-guestbook-page'), 10) || 0
        gbScrollToPage(idx)
      })
    })
  }

  function gbScrollToPage(idx) {
    if (!gbScroller) return
    var pageWidth = gbScroller.clientWidth
    gbScroller.scrollTo({ left: idx * pageWidth, behavior: 'smooth' })
  }

  // Expose for submit handler rebuild
  window.renderGuestbookDots = renderGuestbookDots

  if (gbScroller) {
    // Initial render (wait a tick for layout)
    setTimeout(renderGuestbookDots, 0)

    var gbScrollTimer
    gbScroller.addEventListener('scroll', function() {
      if (gbScrollTimer) clearTimeout(gbScrollTimer)
      gbScrollTimer = setTimeout(gbUpdateActiveDot, 60)
    })

    // Drag-to-scroll for PC
    var gbDown = false
    var gbStartX = 0
    var gbStartScroll = 0
    var gbMoved = false

    gbScroller.addEventListener('mousedown', function(e) {
      gbDown = true
      gbMoved = false
      gbStartX = e.pageX
      gbStartScroll = gbScroller.scrollLeft
      gbScroller.classList.add('dragging')
    })

    document.addEventListener('mousemove', function(e) {
      if (!gbDown) return
      var walk = e.pageX - gbStartX
      if (Math.abs(walk) > 5) gbMoved = true
      gbScroller.scrollLeft = gbStartScroll - walk
    })

    document.addEventListener('mouseup', function() {
      if (!gbDown) return
      gbDown = false
      gbScroller.classList.remove('dragging')
    })

    gbScroller.addEventListener('click', function(e) {
      if (gbMoved) { e.preventDefault(); e.stopPropagation(); gbMoved = false }
    }, true)

    gbScroller.querySelectorAll('img').forEach(function(img) { img.setAttribute('draggable', 'false') })

    var gbResizeTimer
    window.addEventListener('resize', function() {
      if (gbResizeTimer) clearTimeout(gbResizeTimer)
      gbResizeTimer = setTimeout(function() {
        renderGuestbookDots()
        var pageWidth = gbScroller.clientWidth
        if (pageWidth <= 0) return
        var idx = Math.round(gbScroller.scrollLeft / pageWidth)
        gbScroller.scrollTo({ left: idx * pageWidth, behavior: 'auto' })
      }, 150)
    })
  }

})()
</script>
<script src="/js/donate.js"></script>
<% if (previewMode) { %>
<script>
;(function () {
  'use strict'

  function getEditableTarget(element) {
    return element ? element.closest('[data-admin-editable="true"]') : null
  }

  function selectTarget(targetName) {
    document.querySelectorAll('[data-admin-editable="true"]').forEach(function (el) {
      el.classList.toggle('is-admin-selected', el.getAttribute('data-admin-target') === targetName)
    })

    var active = document.querySelector('[data-admin-editable="true"][data-admin-target="' + targetName + '"]')
    if (active) {
      active.scrollIntoView({ behavior: 'smooth', block: 'center' })
    }
  }

  document.addEventListener('click', function (event) {
    var target = getEditableTarget(event.target)
    if (!target) return

    event.preventDefault()
    event.stopPropagation()
    window.parent.postMessage({
      type: 'admin-preview-select',
      target: target.getAttribute('data-admin-target')
    }, '*')
  }, true)

  document.addEventListener('submit', function (event) {
    if (getEditableTarget(event.target)) {
      event.preventDefault()
      event.stopPropagation()
    }
  }, true)

  window.addEventListener('message', function (event) {
    if (!event.data || typeof event.data !== 'object') return
    if (event.data.type === 'admin-preview-highlight' && event.data.target) {
      selectTarget(event.data.target)
    }
  })

  window.parent.postMessage({ type: 'admin-preview-ready' }, '*')
})()
</script>
<% } %>
</body>
</html>
