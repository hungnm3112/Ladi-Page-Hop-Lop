<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, interactive-widget=resizes-content">
  <title><%= content.hero.titleLine1 %> <%= content.hero.titleLine2 %> – <%= content.hero.school %></title>
  <meta name="description" content="<%= content.hero.description %>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/donate.css">
  <link rel="icon" type="image/gif" href="/images/icon.gif">
  <link rel="shortcut icon" href="/images/icon.gif">
  <% if (previewMode) { %>
  <style>
    body.admin-preview-mode [data-admin-editable="true"] {
      position: relative;
      cursor: pointer !important;
      outline: 2px dashed rgba(184, 134, 51, 0);
      outline-offset: 8px;
      transition: outline-color 0.18s ease, box-shadow 0.18s ease;
    }
    body.admin-preview-mode [data-admin-editable="true"]:hover,
    body.admin-preview-mode [data-admin-editable="true"].is-admin-selected {
      outline-color: rgba(184, 134, 51, 0.95);
      box-shadow: 0 0 0 6px rgba(184, 134, 51, 0.12);
    }
    body.admin-preview-mode [data-admin-editable="true"]::after {
      content: attr(data-admin-label);
      position: absolute;
      top: 12px;
      left: 12px;
      z-index: 20;
      padding: 6px 10px;
      border-radius: 999px;
      background: rgba(16, 24, 40, 0.92);
      color: #fff;
      font: 700 16.5px/1 'Open Sans', sans-serif;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      opacity: 0;
      transform: translateY(-4px);
      transition: opacity 0.18s ease, transform 0.18s ease;
      pointer-events: none;
    }
    body.admin-preview-mode [data-admin-editable="true"]:hover::after,
    body.admin-preview-mode [data-admin-editable="true"].is-admin-selected::after {
      opacity: 1;
      transform: translateY(0);
    }
  </style>
  <% } %>
</head>
<body data-page="home"<% if (previewMode) { %> class="admin-preview-mode"<% } %>>

<!-- ══ STICKY NAV ═══════════════════════════════════════ -->
<nav class="navbar" id="navbar">
  <a href="#" class="navbar-brand js-scroll" data-target="hero">
    <img src="<%= content.hero.logo %>" alt="Logo" onerror="this.style.display='none'">
    <span>CHẠM KÝ ỨC - NỐI THANH XUÂN</span>
  </a>
  <button class="navbar-toggle" id="navbar-toggle" type="button" aria-label="Mở điều hướng" aria-expanded="false" aria-controls="navbar-mobile">
    <span></span><span></span><span></span>
  </button>
  <ul class="navbar-links">
    <li><a href="#gioi-thieu">GIỚI THIỆU</a></li>
    <li><a href="#lich-trinh">LỊCH TRÌNH</a></li>
    <li><a href="#da-dang-ky">ĐÃ ĐĂNG KÝ</a></li>
    <li><a href="#ung-ho">ỦNG HỘ</a></li>
    <li><a href="#thu-vien-anh">THƯ VIỆN ẢNH</a></li>
    <li><a href="#luu-but">LƯU BÚT</a></li>
    <li><a href="#lien-he">LIÊN HỆ</a></li>
  </ul>
  <div class="navbar-actions">
    <a href="/donate" class="btn-outline-gold" data-donate-open>ỦNG HỘ</a>
    <a href="#dang-ky" class="btn-gold" data-register-open>ĐĂNG KÝ</a>
  </div>
</nav>
<div class="navbar-mobile" id="navbar-mobile" hidden>
  <a href="#gioi-thieu">GIỚI THIỆU</a>
  <a href="#lich-trinh">LỊCH TRÌNH</a>
  <a href="#da-dang-ky">ĐÃ ĐĂNG KÝ</a>
  <a href="#ung-ho">ỦNG HỘ</a>
  <a href="#thu-vien-anh">THƯ VIỆN ẢNH</a>
  <a href="#luu-but">LƯU BÚT</a>
  <a href="#lien-he">LIÊN HỆ</a>
  <div class="navbar-mobile-actions">
    <a href="/donate" class="btn-outline-gold" data-donate-open>ỦNG HỘ</a>
    <a href="#dang-ky" class="btn-gold" data-register-open>ĐĂNG KÝ</a>
  </div>
</div>

<!-- ══ FIXED CTA ════════════════════════════════════════ -->
<a href="#dang-ky" class="fixed-cta" data-register-open>ĐĂNG KÝ NGAY</a>

<!-- ══ SECTION 1 — HERO ══════════════════════════════════ -->
<div class="mobile-bottom-nav" aria-label="Hành động nhanh trên điện thoại">
  <a href="/donate" class="btn-outline-gold" data-donate-open>Ủng hộ</a>
  <a href="#dang-ky" class="btn-gold" data-register-open>Đăng ký</a>
</div>

<section class="hero" id="hero"<% if (content.hero && content.hero.bgColor) { %> style="background: <%= content.hero.bgColor %>"<% } %>>
  <div class="hero-content"<% if (previewMode) { %> data-admin-editable="true" data-admin-target="hero" data-admin-label="Hero"<% } %>>

    <div class="hero-logo-wrap">
      <%
        var heroAttendees = (registeredSummary && registeredSummary.attendees) ? registeredSummary.attendees : []
        var HERO_RING_NODES = 30
        var HERO_RING_SIZE = 480
        var HERO_DOT_SIZE = 8
        var HERO_RING_RADIUS = (HERO_RING_SIZE / 2) - HERO_DOT_SIZE
        var HERO_RING_PALETTE = [
          'rgb(184,134,51)', 'rgb(208,157,78)', 'rgb(1,20,139)', 'rgb(51,78,184)',
          'rgb(159,114,40)', 'rgb(15,42,158)', 'rgb(228,190,117)', 'rgb(75,101,198)'
        ]
        var heroRingItems = []
        if (heroAttendees.length > 0) {
          for (var hri = 0; hri < HERO_RING_NODES; hri++) {
            heroRingItems.push(heroAttendees[hri % heroAttendees.length])
          }
        }
      %>
      <div class="hero-constellation" data-hero-constellation aria-hidden="true">
        <div class="hero-constellation-spinner">
          <div class="hero-constellation-circle"></div>
          <% for (var hi = 0; hi < HERO_RING_NODES; hi++) {
               var hAngle = (hi * (360 / HERO_RING_NODES)) - 90
               var hRad = hAngle * Math.PI / 180
               var hLeftPct = (50 + (HERO_RING_RADIUS / HERO_RING_SIZE) * 100 * Math.cos(hRad)).toFixed(4)
               var hTopPct  = (50 + (HERO_RING_RADIUS / HERO_RING_SIZE) * 100 * Math.sin(hRad)).toFixed(4)
               var hPerson = heroRingItems[hi] || null
               var hColor = HERO_RING_PALETTE[hi % HERO_RING_PALETTE.length]
               var hPulseDelay = (hi % 2 === 0) ? '0s' : '1.5s'
               var hAppearDelay = (hi * 0.04).toFixed(2) + 's'
               var hLabel = hPerson ? (hPerson.name + (hPerson.className ? '  – ' + hPerson.className : '')) : ''
          %>
          <div class="hero-constellation-node"
               data-constellation-node
               style="left: <%= hLeftPct %>%; top: <%= hTopPct %>%; animation-delay: <%= hAppearDelay %>;">
            <div class="hero-constellation-counter">
              <div class="hero-constellation-pulse" style="animation-delay: <%= hPulseDelay %>;">
                <span class="hero-constellation-dot" style="background: <%= hColor %>;"></span>
              </div>
              <% if (hLabel) { %>
              <span class="hero-constellation-label"><%= hLabel %></span>
              <% } %>
            </div>
          </div>
          <% } %>
        </div>
      </div>
      <img src="<%= content.hero.logo %>" alt="Logo" class="hero-logo" onerror="this.style.display='none'">
    </div>

    <p class="hero-label"><%= content.hero.label || 'CHẠM KÝ ỨC - NỐI THANH XUÂN' %></p>

    <%
      function wrapHeroNumbers(text) {
        var escaped = String(text).replace(/[&<>"']/g, function(c) {
          return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]
        })
        return escaped.replace(/(\d+)/g, '<span class="hero-title-number">$1</span>')
      }
    %>
    <h1 class="hero-title">
      <span class="hero-title-line1"><%- wrapHeroNumbers(content.hero.titleLine1 || 'Kỷ Niệm 20 Năm') %></span>
      <span class="hero-title-line2"><%- wrapHeroNumbers(content.hero.titleLine2 || 'Ngày Ra Trường') %></span>
    </h1>

    <p class="hero-school"><%= content.hero.school || '' %></p>
    <p class="hero-tagline"><%= content.hero.tagline || '' %></p>
    <p class="hero-desc"><%= content.hero.description || '' %></p>

    <div class="hero-buttons">
      <a href="#dang-ky" class="btn-hero-primary" data-register-open>
        <%= content.hero.ctaPrimaryText || 'Đăng Ký Tham Gia' %>
      </a>
      <a href="<%= content.hero.ctaSecondaryUrl || '#lich-trinh' %>" class="btn-hero-secondary">
        <%= content.hero.ctaSecondaryText || 'Xem Lịch Trình →' %>
      </a>
    </div>

    <div class="hero-btn-dots" aria-hidden="true">
      <span></span><span></span><span></span>
    </div>

    <div class="countdown" id="countdown">
      <div class="cd-item">
        <span class="cd-num" id="cd-days">--</span>
        <span class="cd-label">Ngày</span>
      </div>
      <span class="cd-sep">·</span>
      <div class="cd-item">
        <span class="cd-num" id="cd-hours">--</span>
        <span class="cd-label">Giờ</span>
      </div>
      <span class="cd-sep">·</span>
      <div class="cd-item">
        <span class="cd-num" id="cd-minutes">--</span>
        <span class="cd-label">Phút</span>
      </div>
      <span class="cd-sep">·</span>
      <div class="cd-item">
        <span class="cd-num" id="cd-seconds">--</span>
        <span class="cd-label">Giây</span>
      </div>
    </div>

  </div>
</section>

<!-- ══ SECTION 2 — THƯ NGỎ (Giới thiệu) ════════════════ -->
<section class="section intro-section" id="gioi-thieu">
  <div class="section-inner section-inner--narrow">

    <div class="section-header reveal"<% if (previewMode) { %> data-admin-editable="true" data-admin-target="about" data-admin-label="Gioi thieu"<% } %>>
      <p class="section-label"><%= content.about.label || 'THƯ NGỎ' %></p>
      <h2 class="section-title"><%= content.about.title || 'Lời Mời Từ Trái Tim' %></h2>
      <div class="title-underline"></div>
      <p class="section-subtitle"><%= content.about.subtitle || '' %></p>
    </div>

    <% if (content.about && content.about.content) { %>
    <div class="intro-letter reveal"<% if (previewMode) { %> data-admin-editable="true" data-admin-target="about" data-admin-label="Gioi thieu"<% } %>>
      <p><%= content.about.content %></p>
      <p class="intro-signature"><%= content.about.signature || '– Ban Tổ Chức –' %></p>
    </div>
    <% } %>

    <div class="info-cards reveal"<% if (previewMode) { %> data-admin-editable="true" data-admin-target="event" data-admin-label="Su kien"<% } %>>
      <div class="info-card">
        <div class="info-card-icon"><i class="fa-solid fa-calendar-days" aria-hidden="true"></i></div>
        <div class="info-card-label">THỜI GIAN</div>
        <div class="info-card-value"><%= eventDateFormatted %></div>
      </div>
      <div class="info-card">
        <div class="info-card-icon"><i class="fa-solid fa-location-dot" aria-hidden="true"></i></div>
        <div class="info-card-label">ĐỊA ĐIỂM</div>
        <div class="info-card-value"><%= content.event.venue %></div>
      </div>
      <div class="info-card">
        <div class="info-card-icon"><i class="fa-solid fa-users" aria-hidden="true"></i></div>
        <div class="info-card-label">ĐỐI TƯỢNG</div>
        <div class="info-card-value"><%= content.event.target || 'Cựu HS niên khóa 03-06' %></div>
      </div>
      <div class="info-card">
        <div class="info-card-icon"><i class="fa-solid fa-phone" aria-hidden="true"></i></div>
        <div class="info-card-label">LIÊN HỆ</div>
        <div class="info-card-value"><%= content.event.contact || '' %></div>
      </div>
    </div>

  </div>
</section>

<!-- ══ SECTION 3 — LỊCH TRÌNH ════════════════════════════ -->
<% if (content.schedule) { %>
<section class="section schedule-section" id="lich-trinh"<% if (previewMode) { %> data-admin-editable="true" data-admin-target="schedule" data-admin-label="Lich trinh"<% } %>>
  <div class="section-inner">

    <div class="section-header reveal">
      <p class="section-label"><%= content.schedule.label || 'LỊCH TRÌNH' %></p>
      <h2 class="section-title"><%= content.schedule.title || 'Chương Trình Sự Kiện' %></h2>
      <div class="title-underline"></div>
      <p class="section-subtitle"><%= content.schedule.subtitle || '' %></p>
    </div>

    <% if (scheduleActivities && scheduleActivities.length > 0) { %>
    <div class="activity-icons reveal">
      <% scheduleActivities.forEach(function(act) { %>
      <div class="activity-icon">
        <span class="activity-icon-symbol"><i class="<%= act.icon %>" aria-hidden="true"></i></span>
        <span class="activity-icon-label"><%= act.label %></span>
      </div>
      <% }) %>
    </div>
    <% } %>

    <% if (content.schedule.days && content.schedule.days.length > 0) { %>
    <div class="timeline reveal">
      <% content.schedule.days.forEach(function(day) { %>
      <div class="timeline-day">
        <div class="timeline-day-header">
          <span class="timeline-day-badge"><%= day.label %></span>
          <span class="timeline-day-date"><%= day.date %></span>
          <div class="timeline-day-divider"></div>
        </div>
        <% day.items.forEach(function(item) { %>
        <div class="timeline-item">
          <div class="timeline-time"><%= item.time %><% if (item.endTime) { %>–<%= item.endTime %><% } %></div>
          <div class="timeline-dot"></div>
          <div>
            <div class="timeline-title"><%= item.title %></div>
            <% if (item.desc) { %><div class="timeline-desc"><%= item.desc %></div><% } %>
          </div>
        </div>
        <% }) %>
      </div>
      <% }) %>
    </div>
    <% } %>

  </div>
</section>
<% } %>

<!-- ══ SECTION 4 — ĐÃ ĐĂNG KÝ ════════════════════════════ -->
<% if (content.registered) { %>
<section class="section registered-section" id="da-dang-ky"<% if (previewMode) { %> data-admin-editable="true" data-admin-target="registered" data-admin-label="Dang ky"<% } %>>
  <div class="section-inner section-inner--narrow">
    <% var registeredClasses = registeredSummary.classes || [] %>
    <% var registeredAttendees = registeredSummary.attendees || [] %>

    <div class="section-header reveal">
      <p class="section-label"><%= registeredSummary.label || 'DANH SÁCH' %></p>
      <h2 class="section-title"><%= registeredSummary.title || 'Đã Đăng Ký Tham Gia' %></h2>
      <div class="title-underline"></div>
      <p class="section-subtitle"><%= registeredSummary.subtitle || '' %></p>
    </div>

    <div class="registered-tabs reveal">
      <button class="registered-tab active" type="button" data-registered-tab="stats">THỐNG KÊ</button>
      <button class="registered-tab" type="button" data-registered-tab="list">DANH SÁCH CHI TIẾT</button>
    </div>

    <div class="registered-panels reveal">
      <div class="registered-panel active" data-registered-panel="stats">
        <div class="registered-stat">
          <div class="registered-number"><%= registeredSummary.total || 0 %></div>
          <p class="registered-sub">người đã đăng ký</p>
          <% if (registeredSummary.classCount) { %>
          <p class="registered-sub-gold"><%= registeredSummary.classCount %></p>
          <% } %>
        </div>

        <% if (registeredSummary.classes && registeredSummary.classes.length > 0 && registeredSummary.total > 0) {
             var maxCount = Math.max.apply(null, registeredSummary.classes.map(function(c) { return c.count || 0 }))
        %>
        <div class="bar-chart">
          <% registeredClasses.forEach(function(cls) { %>
          <% var barWidth = maxCount > 0 ? Math.round((cls.count / maxCount) * 100) : 0 %>
          <div class="bar-row">
            <button class="bar-label bar-label-button" type="button" data-registered-jump="<%= cls.name %>"><%= cls.name %></button>
            <div class="bar-track">
              <div class="bar-fill" data-bar-width="<%= barWidth %>"></div>
            </div>
            <div class="bar-count"><%= cls.count %></div>
          </div>
          <% }) %>
        </div>
        <p class="registered-hint">Bấm vào tên lớp để xem danh sách chi tiết.</p>
        <% } else { %>
        <div class="registered-empty">
          <p>Chưa có dữ liệu đăng ký để hiển thị thống kê.</p>
        </div>
        <% } %>
      </div>

      <div class="registered-panel" data-registered-panel="list">
        <% if (registeredClasses.length > 0) { %>
        <div class="registered-class-filters" id="registered-class-filters">
          <% registeredClasses.forEach(function(cls) { %>
          <button
            class="registered-class-chip"
            type="button"
            data-class-filter="<%= cls.name %>">
            <%= cls.name %> (<%= cls.count %>)
          </button>
          <% }) %>
          <button class="registered-class-chip active registered-class-chip-all" type="button" data-class-filter="all">
            TẤT CẢ (<%= registeredSummary.total || 0 %>)
          </button>
        </div>
        <% } %>

        <% if (registeredAttendees.length > 0) { %>
        <div class="registered-list">
          <div class="registered-list-head">
            <span>STT</span>
            <span>Họ và tên</span>
            <span>Lớp</span>
            <span>Ghi chú</span>
            <span>Trạng thái</span>
          </div>
          <% registeredAttendees.forEach(function(item, index) { %>
          <div class="registered-list-row" data-registered-row data-class-name="<%= item.className || 'Khác' %>">
            <span class="registered-cell-index" data-row-index><%= index + 1 %></span>
            <span><%= item.name %></span>
            <span><%= item.className || 'Đang cập nhật' %></span>
            <span><%= item.note || '–' %></span>
            <span><span class="registered-status"><%= item.status || 'Chờ xác nhận' %></span></span>
          </div>
          <% }) %>
        </div>
        <div class="registered-pagination" id="registered-pagination"></div>
        <% } else { %>
        <div class="registered-empty">
          <p>Danh sách chi tiết sẽ hiển thị ngay khi BTC cập nhật người tham gia.</p>
        </div>
        <% } %>
      </div>
    </div>

  </div>
</section>
<% } %>

<% if (donateSummary) { %>
<section class="section donate-home-section" id="ung-ho"<% if (previewMode) { %> data-admin-editable="true" data-admin-target="donate" data-admin-label="Ung ho"<% } %>>
  <div class="donate-hero-page donate-home-hero-page">
    <div class="donate-hero-inner donate-home-inner">
      <div class="section-header donate-home-header">
        <p class="section-label"><%= donateSummary.label || 'ỦNG HỘ' %></p>
        <h2 class="donate-hero-title donate-home-title">
          <span><%= donateSummary.title || 'Đóng Góp Cho' %></span>
          <span class="donate-hero-title-accent"><%= donateSummary.titleAccent || 'Ngày Hội Ngộ' %></span>
        </h2>
        <div class="title-underline"></div>
        <p class="section-subtitle donate-hero-copy"><%= donateSummary.subtitle || '' %></p>
      </div>

      <div class="donate-hero-stats donate-home-stats">
        <div class="donate-stat-card">
          <strong><%= Number(donateSummary.totalAmount || 0).toLocaleString('vi-VN') %></strong>
          <span>VND đã đóng góp</span>
        </div>
        <div class="donate-stat-card">
          <strong><%= donateSummary.donorCount || 0 %></strong>
          <span>Người đóng góp</span>
        </div>
      </div>

      <div class="donate-hero-actions donate-home-actions">
        <button class="btn-gold donate-hero-button" type="button" data-donate-open><%= donateSummary.ctaText || 'Đóng Góp Ngay' %></button>
        <a href="#donate-board" class="btn-outline-gold">Xem bảng xếp hạng</a>
      </div>
    </div>
  </div>

  <div class="donate-board-section donate-home-board-section" id="donate-board">
    <%- include('partials/donate-board', { donateSummary: donateSummary }) %>
  </div>
</section>
<% } %>

<!-- Registration Modal -->
<%
  var registerClassOptions = []
  if (content.registered && Array.isArray(content.registered.classOptions) && content.registered.classOptions.length > 0) {
    registerClassOptions = content.registered.classOptions
  } else if (content.registered && Array.isArray(content.registered.classes)) {
    registerClassOptions = content.registered.classes
      .map(function(item) { return item && item.name ? item.name : '' })
      .filter(Boolean)
  }
%>
<div class="register-modal" id="register-modal" aria-hidden="true" aria-modal="true" role="dialog">
  <div class="modal-bg" id="register-modal-bg"></div>
  <div class="register-modal-box">
    <button class="register-modal-close" id="close-register-modal" aria-label="Đóng"><i class="fa-solid fa-xmark" aria-hidden="true"></i></button>
    <div class="register-modal-header">
      <p class="register-modal-label">ĐĂNG KÝ</p>
      <h3 class="register-modal-title">Đăng Ký Tham Gia</h3>
      <p class="register-modal-subtitle">Điền thông tin để xác nhận tham dự</p>
    </div>

    <form id="register-form" novalidate>
      <div class="register-form-group">
        <label class="register-form-label" for="register-name">HỌ VÀ TÊN *</label>
        <input class="register-form-input" type="text" id="register-name" name="name" placeholder="Nhập họ và tên đầy đủ" maxlength="80" required>
      </div>

      <div class="register-form-row">
        <div class="register-form-group">
          <label class="register-form-label" for="register-class">LỚP *</label>
          <select class="register-form-input" id="register-class" name="className" required>
            <option value="">-- Chọn lớp --</option>
            <% registerClassOptions.forEach(function(className) { %>
            <option value="<%= className %>"><%= className %></option>
            <% }) %>
          </select>
        </div>
        <div class="register-form-group">
          <label class="register-form-label" for="register-phone">SỐ ĐIỆN THOẠI *</label>
          <input class="register-form-input" type="text" id="register-phone" name="phone" placeholder="0912 345 678" maxlength="20" required>
        </div>
      </div>

      <div class="register-form-group">
